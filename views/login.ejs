<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Dynamic QR Generator</title>
    <link rel="icon" type="image/png" href="/images/qrconnect logo.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #000000;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            background: #1a1a1a;
            border-radius: 20px;
            padding: 40px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        .logo {
            max-width: 150px;
            margin-bottom: 30px;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }

        h1 {
            color: #ffffff;
            margin-bottom: 10px;
            font-size: 28px;
        }

        p {
            color: #888;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .google-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: #ffffff;
            color: #333;
            padding: 14px 24px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            width: 100%;
            font-size: 16px;
        }

        .google-btn:hover {
            background: #f0f0f0;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }

        .google-btn i {
            font-size: 20px;
        }

        .error-message {
            background: #ff4444;
            color: white;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .success-message {
            background: #4CAF50;
            color: white;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .footer {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #333;
            color: #666;
            font-size: 12px;
        }

        @media (max-width: 480px) {
            .login-container {
                padding: 30px 20px;
            }

            h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <img src="/images/qrconnect logo.png" alt="QR Connect" class="logo">
        <h1>Dynamic QR Generator</h1>
        <p>Create your business QR code in minutes</p>
        
        <div id="errorMsg" class="error-message" style="display: none;"></div>
        <div id="successMsg" class="success-message" style="display: none;"></div>

        <a href="/auth/google" class="google-btn">
            <i class="fab fa-google"></i>
            Continue with Google
        </a>
    </div>

    <script>
        const errorMsg = document.getElementById('errorMsg');
        const successMsg = document.getElementById('successMsg');

        function showError(msg) {
            errorMsg.textContent = msg;
            errorMsg.style.display = 'block';
            successMsg.style.display = 'none';
        }

        // Check for URL error parameters
        const urlParams = new URLSearchParams(window.location.search);
        const error = urlParams.get('error');
        const urlErrorMsg = urlParams.get('msg');
        
        if (error) {
            let errorMessage = 'Authentication failed. ';
            
            switch(error) {
                case 'auth_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'Google authentication error. Please try again.';
                    break;
                case 'no_user':
                    errorMessage = 'Unable to create account. Please try again or contact support.';
                    break;
                case 'login_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'Login failed. Please try again.';
                    break;
                case 'save_error':
                    errorMessage = 'Session error. Please try logging in again.';
                    break;
                case 'config_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'Google OAuth is not configured. Please contact support.';
                    break;
                case 'strategy_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'Google OAuth is not available. Please contact support.';
                    break;
                case 'db_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'Database connection failed. Please try again.';
                    break;
                case 'unexpected_error':
                    errorMessage = urlErrorMsg ? decodeURIComponent(urlErrorMsg) : 'An unexpected error occurred. Please try again.';
                    break;
                default:
                    errorMessage = 'Authentication failed. Please try again.';
            }
            
            showError(errorMessage);
        }
    </script>
</body>
</html>

